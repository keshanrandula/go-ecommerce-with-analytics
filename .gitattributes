# Custom GitHub Linguist Overrides

# Hide large frontend source files to make Go the primary language
frontend/src/App.jsx linguist-detectable=false
frontend/src/components/Shop.jsx linguist-detectable=false
frontend/src/components/CartDrawer.jsx linguist-detectable=false
frontend/src/components/admin/** linguist-detectable=false

# Keep configuration, node dependencies, public assets, and build setup ignored
frontend/public/** linguist-detectable=false
frontend/package-lock.json linguist-detectable=false
frontend/package.json linguist-detectable=false
frontend/.oxlintrc.json linguist-detectable=false
frontend/postcss.config.js linguist-detectable=false
frontend/tailwind.config.js linguist-detectable=false
frontend/vite.config.js linguist-detectable=false
frontend/*.html linguist-detectable=false
frontend/*.json linguist-detectable=false
frontend/*.md linguist-detectable=false


